<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>remote-notification</string>
	</array>
	<key>ZoneBuddyAPISecret</key>
	<string>$(ZONEBUDDY_API_SECRET)</string>
	<key>ZoneBuddyDevServerURL</key>
	<string>$(ZONEBUDDY_DEV_SERVER_URL)</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>ZoneBuddy needs access to your music library to play playlists during workouts.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>ZoneBuddy connects to a local server to deliver Live Activity updates during workouts.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
